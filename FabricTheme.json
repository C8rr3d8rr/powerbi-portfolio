{
  "name": "Fabric Analytics Theme",
  "dataColors": [
    "#1E3A5F",
    "#2E5C8A",
    "#4F8FBF",
    "#7FA6C8",
    "#A7C1D9",
    "#F39C12",
    "#E74C3C"
  ],
  "background": "#F5F7FA",
  "foreground": "#1E3A5F",
  "tableAccent": "#1E3A5F",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 16,
            "color": { "solid": { "color": "#1E3A5F" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#1E3A5F" } },
            "fontSize": 32
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#2E5C8A" } },
            "fontSize": 14
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridHorizontal": true,
            "outlineColor": { "solid": { "color": "#E6EAF0" } }
          }
        ]
      }
    }
  }
}